{
  "name": "harness-desktop",
  "private": true,
  "description": "Harness Desktop — AI Coding workflow governance desktop application",
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --filter @harness/desktop --filter @harness/renderer --filter @harness/contracts test",
    "test:e2e": "playwright test",
    "build": "pnpm -r build",
    "package": "pnpm --filter @harness/desktop package"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
