{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness Desktop RPC Contract",
  "description": "Shared JSON Schema for TypeScript and Python RPC contract validation.",

  "CommandMeta": {
    "type": "object",
    "required": ["requestId", "projectId"],
    "properties": {
      "requestId": { "type": "string" },
      "projectId": { "type": "string" },
      "runId": { "type": "string" },
      "expectedRevision": { "type": "string" }
    }
  },

  "RpcRequest": {
    "type": "object",
    "required": ["jsonrpc", "method", "id"],
    "properties": {
      "jsonrpc": { "const": "2.0" },
      "method": { "type": "string" },
      "params": { "type": "object" },
      "id": { "type": "string" },
      "meta": { "$ref": "#/CommandMeta" }
    }
  },

  "RpcResponse": {
    "type": "object",
    "required": ["jsonrpc", "id"],
    "properties": {
      "jsonrpc": { "const": "2.0" },
      "result": {},
      "error": { "$ref": "#/RpcError" },
      "id": { "type": "string" }
    }
  },

  "RpcError": {
    "type": "object",
    "required": ["code", "message"],
    "properties": {
      "code": { "type": "string" },
      "message": { "type": "string" },
      "pointer": { "type": "string" }
    }
  },

  "RuntimeEvent": {
    "type": "object",
    "required": ["type", "timestamp"],
    "properties": {
      "type": {
        "type": "string",
        "enum": [
          "StateChanged",
          "WorkflowChanged",
          "ExecutionOutput",
          "ToolCall",
          "ApprovalRequested",
          "GateEvaluated",
          "ArtifactChanged",
          "ExecutorExited",
          "RuntimeWarning"
        ]
      },
      "payload": { "type": "object" },
      "timestamp": { "type": "string", "format": "date-time" }
    }
  },

  "examples": {
    "RpcRequest": {
      "jsonrpc": "2.0",
      "method": "runtime.health",
      "id": "req-001",
      "meta": {
        "requestId": "req-001",
        "projectId": "test-project",
        "expectedRevision": "abc123"
      }
    },
    "RpcResponse": {
      "jsonrpc": "2.0",
      "result": { "status": "healthy", "runtime_version": "0.0.0", "protocol_version": "1.0" },
      "id": "req-001"
    },
    "RpcError": {
      "code": "AUTH_FAILED",
      "message": "Invalid or missing runtime token",
      "pointer": "/meta/headers/authorization"
    },
    "RuntimeEvent": {
      "type": "StateChanged",
      "payload": { "run_id": "test-001", "current_node": "DEVELOPMENT" },
      "timestamp": "2026-07-21T00:00:00Z"
    }
  }
}
